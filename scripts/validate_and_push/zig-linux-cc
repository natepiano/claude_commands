#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -n "${VALIDATE_TARGET_DIR:-}" ]; then
  ZIG_TARGET_DIR="${VALIDATE_TARGET_DIR}"
elif [ -n "${CARGO_TARGET_DIR:-}" ]; then
  ZIG_TARGET_DIR="${CARGO_TARGET_DIR}"
else
  ZIG_TARGET_DIR="${SCRIPT_DIR}/target"
fi

export ZIG_GLOBAL_CACHE_DIR="${ZIG_GLOBAL_CACHE_DIR:-${ZIG_TARGET_DIR}/zig-global-cache}"
export ZIG_LOCAL_CACHE_DIR="${ZIG_LOCAL_CACHE_DIR:-${ZIG_TARGET_DIR}/zig-local-cache}"
ZIG_LINUX_TARGET="${VALIDATE_LINUX_ZIG_TARGET:-x86_64-linux-gnu.2.36}"

args=()
skip_next=0
for arg in "$@"; do
  if [ "$skip_next" -eq 1 ]; then
    skip_next=0
    continue
  fi
  case "$arg" in
    --target=x86_64-unknown-linux-gnu)
      ;;
    --target)
      skip_next=1
      ;;
    *)
      args+=("$arg")
      ;;
  esac
done

exec zig cc -target "$ZIG_LINUX_TARGET" "${args[@]}"
