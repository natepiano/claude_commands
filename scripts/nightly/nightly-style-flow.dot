digraph nightly_style {
    // ┌─────────────────────────────────────────────────────────────────┐
    // │ LAYOUT GUIDE                                                    │
    // │                                                                 │
    // │ Render:  python3 render-flow.py                                 │
    // │          (runs neato -n2, then injects cluster borders + viewBox)│
    // │                                                                 │
    // │ Cluster membership is parsed from this file automatically —     │
    // │ just add/remove nodes inside the subgraph cluster_* blocks.     │
    // │ The render script reads cluster labels/colors from here too.    │
    // │                                                                 │
    // │ Positions use Graphviz points (1 inch = 72pt).                  │
    // │ Node width=2.4 → 172.8pt. Y spacing between rows: ~55-65pt.    │
    // │                                                                 │
    // │ Column layout (border-to-border gaps, not center gaps):         │
    // │   1. Find widest node per phase (width * 72)                    │
    // │   2. cluster_width = max_content_width + 2 * pad (pad ≈ 25pt)  │
    // │   3. Gap between clusters ≈ 30pt                                │
    // │   4. Phase centers = midpoint of each cluster x-range           │
    // │                                                                 │
    // │ To add a node: add it inside the right subgraph block with a    │
    // │   pos="<center_x>,<y>!" attribute, add edges, re-render.        │
    // │ To remove: delete the node + its edges, re-render.              │
    // │ To add a phase: add a new subgraph cluster_* block, compute     │
    // │   its x-range, shift subsequent phases right, re-render.        │
    // └─────────────────────────────────────────────────────────────────┘
    fontname="Helvetica"
    node [fontname="Helvetica" fontsize=10 style=filled shape=box margin="0.12,0.06" width=2.4 height=0.5]
    edge [fontname="Helvetica" fontsize=8]
    overlap=false
    splines=true

    node [fillcolor="#e8f4f8" color="#2980b9"]

    start [label="Nightly Build (4:00 AM)" shape=oval fillcolor="#f0e6ff" color="#8e44ad" width=2.2 pos="141.4,890!"]

    // Cluster-first layout in points:
    // Phase 1 range = [30.0, 252.8], center = 141.4
    // Phase 2 range = [282.8, 505.6], center = 394.2
    // Phase 3 range = [535.6, 864.8], center = 700.2
    // Inter-cluster gap = 30.0

    // ══════ Phase 1: Clean + Rebuild (x center = 141.4) ══════
    subgraph cluster_build {
        label="Phase 1: Clean + Rebuild"
        style=dashed color="#95a5a6" fontcolor="#7f8c8d" fontsize=9
        margin=12

        foreach_project [label="For each ~/rust/*\n(skip excluded, worktrees,\n_style_fix, unmodified)" height=0.65 pos="141.4,790!"]
        clean [label="cargo clean" pos="141.4,720!"]
        build [label="cargo build --workspace" pos="141.4,660!"]
        clippy_build [label="cargo clippy -D warnings" pos="141.4,600!"]
        warmup [label="Warmup\n(launch + kill selected apps)" height=0.55 pos="141.4,535!"]
        style_enabled [label="style_eval\nenabled?" shape=diamond fillcolor="#fef9e7" color="#f39c12" width=1.4 height=0.8 pos="141.4,455!"]
    }

    // ══════ Phase 2: Style Evaluation (x center = 394.2) ══════
    subgraph cluster_eval {
        label="Phase 2: Style Evaluation"
        style=dashed color="#95a5a6" fontcolor="#7f8c8d" fontsize=9
        margin=12

        eval_foreach [label="For each project (parallel)" pos="394.2,790!"]
        load_style [label="Load style guide\n~/.claude/scripts/load-rust-style.sh" height=0.55 pos="394.2,725!"]
        survey [label="Survey project source" pos="394.2,665!"]
        carry_forward [label="Read existing EVALUATION.md\n(carry forward valid findings)" height=0.55 pos="394.2,600!"]
        check_wt_eval [label="_style_fix/\nEVALUATION.md\nexists?" shape=diamond fillcolor="#fef9e7" color="#f39c12" width=1.5 height=0.9 pos="394.2,520!"]
        load_wt_eval [label="Read worktree EVALUATION.md\n(exclude these findings)" height=0.55 pos="394.2,440!"]
        evaluate [label="Find up to 5 NEW violations\n(skip worktree findings)" height=0.55 pos="394.2,370!"]
        write_eval [label="Write EVALUATION.md\n(carried + new)" height=0.55 pos="394.2,300!"]
    }

    // ══════ Phase 3: Style-Fix Worktrees (x center = 700.2) ══════
    subgraph cluster_fix {
        label="Phase 3: Style-Fix Worktrees"
        style=dashed color="#95a5a6" fontcolor="#7f8c8d" fontsize=9
        margin=12

        fix_foreach [label="For each project with\nEVALUATION.md findings" height=0.55 pos="700.2,790!"]
        prechecks [label="Prechecks:\n- no _style_fix dir\n- tree is clean" height=0.65 pos="700.2,720!"]
        create_wt [label="git worktree add\n-b refactor/style\n{project}_style_fix" height=0.65 pos="700.2,645!"]
        mv_eval [label="mv EVALUATION.md → worktree\n(primary starts fresh)" height=0.55 pos="700.2,575!"]
        claude_fix [label="Launch Claude\n(fixes, cargo mend, clippy,\ntests, style review)" fillcolor="#d5f5e3" color="#27ae60" height=0.65 pos="700.2,500!"]
        fix_ok [label="Worktree ready\nfor review" fillcolor="#d5f5e3" color="#27ae60" height=0.55 width=1.8 pos="625.4,425!"]
        fix_fail [label="Failure: mv EVAL\nback, rm worktree" fillcolor="#fadbd8" color="#e74c3c" height=0.55 width=1.8 pos="775.0,425!"]
    }

    report [label="Generate Nightly Report" shape=oval fillcolor="#f0e6ff" color="#8e44ad" width=2.2 pos="447.4,195!"]

    // ══════ Phase 4: Post-Nightly Manual ══════
    subgraph cluster_manual {
        label="Post-Nightly (Manual)"
        style=dashed color="#95a5a6" fontcolor="#7f8c8d" fontsize=9
        margin=12

        review [label="/style_fix_review" pos="447.4,100!"]
        merge [label="/merge_from_branch" pos="447.4,40!"]
        delete_wt [label="/delete_a_worktree" pos="447.4,-20!"]
    }

    // ── Edges ──

    // Start → Phase 1
    start -> foreach_project

    // Phase 1 internal
    foreach_project -> clean -> build -> clippy_build -> warmup -> style_enabled

    // Phase 1 → Phase 2
    style_enabled -> eval_foreach [label="yes"]

    // Phase 1 → Report (skip)
    style_enabled -> report [label="no"]

    // Phase 2 internal
    eval_foreach -> load_style -> survey -> carry_forward -> check_wt_eval
    check_wt_eval -> load_wt_eval [label="yes"]
    check_wt_eval -> evaluate [label="no"]
    load_wt_eval -> evaluate
    evaluate -> write_eval

    // Phase 2 → Phase 3
    write_eval -> fix_foreach [label="all done"]

    // Phase 3 internal
    fix_foreach -> prechecks -> create_wt -> mv_eval -> claude_fix
    claude_fix -> fix_ok [label="success"]
    claude_fix -> fix_fail [label="failure"]

    // Phase 3 → Report
    fix_ok -> report
    fix_fail -> report

    // Report → Manual
    report -> review [style=dotted xlabel="user reviews\nnext day"]
    review -> merge [style=dotted]
    merge -> delete_wt [style=dotted]
}
