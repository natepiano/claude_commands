{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "RUSTC_WRAPPER": "",
    "TMPPREFIX": "/tmp/claude/zsh"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(gh *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git stash *)",
      "Bash(git branch *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git worktree *)",
      "Bash(git clean *)",
      "Bash(git config *)",
      "Bash(git blame *)",
      "Bash(mkdir *)",
      "Bash(rg *)",
      "Bash(rm *)",
      "Bash(sccache *)",
      "Bash(run_test.sh *)",
      "Bash(~/.claude/scripts/release/*)",
      "Bash(//Users/natemccoy/Library/Caches/Mozilla.sccache/**)",
      "Bash(//Users/natemccoy/rust/**/.git/**)",
      "Edit(//Users/natemccoy/.claude/**)",
      "Edit(//Users/natemccoy/Library/Application Support/**)",
      "Read(//Users/natemccoy/rust/**)",
      "Read(//Users/natemccoy/.cargo/registry/src**)",
      "Read(//Users/natemccoy/Library/Application Support/**)",
      "Write(//tmp/claude/**)",
      "Edit(//tmp/claude/**)",
      "Read(//tmp/**)",
      "Read(/private/tmp*)",
      "Read(//var/folders/rf/twhh0jfd243fpltn5k0w1t980000gn/T/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /tmp/claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/hooks/post-tool-use-random-ack.sh --hook"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/hooks/post-tool-use-cargo-check.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/hooks/post-tool-use-basedpyright.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf \"%s%% Press ? for shortcuts\" \"$(basename \"$(pwd)\")\""
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "index.crates.io",
        "static.crates.io",
        "raw.githubusercontent.com",
        "api.github.com",
        "github.com"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "gh",
      "git",
      "taplo",
      "cargo",
      "~/.claude/scripts/validate_and_push/validate_ci.sh"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "additionalDirectories": [
    "/Users/natemccoy/rust",
    "/Users/natemccoy/Library",
    "/tmp",
    "/tmp/claude/"
  ],
  "teammateMode": "tmux",
  "feedbackSurveyState": {
    "lastShownTime": 1754090074729
  },
  "writePaths": [
    "/Users/natemccoy/.cargo",
    "/Users/natemccoy/Library/Application Support/**",
    "/Users/natemccoy/Library/Caches/Mozilla.sccache",
    "/Users/natemccoy/rust",
    "/Users/natemccoy/rust/**/.git",
    "/tmp",
    "/tmp/**",
    "/private/tmp/**"
  ]
}
