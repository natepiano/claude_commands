{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "TMPPREFIX": "/tmp/claude/zsh"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(git *)",
      "Bash(sccache *)",
      "Bash(//Users/natemccoy/Library/Caches/Mozilla.sccache/**)",
      "Bash(//Users/natemccoy/rust/**/.git/**)",
      "Edit(//Users/natemccoy/.claude/**)",
      "Edit(//Users/natemccoy/rust/**)",
      "Edit(//Users/natemccoy/rust/bevy_brp/.claude/commands/**)",
      "Read(//Users/natemccoy/.cargo/registry/src**)",
      "Read(//tmp/**)",
      "Read(//var/folders/rf/twhh0jfd243fpltn5k0w1t980000gn/T/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-lsp-check.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end-lsp-cleanup.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use-random-ack.sh --hook"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use-cargo-check.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/post-tool-use-basedpyright.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf \"%s%% Press ? for shortcuts\" \"$(basename \"$(pwd)\")\""
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "index.crates.io",
        "static.crates.io",
        "raw.githubusercontent.com",
        "api.github.com"
      ],
      "allowLocalBinding": true
    }
  },
  "alwaysThinkingEnabled": true,
  "additionalDirectories": [
    "/Users/natemccoy/rust",
    "/Users/natemccoy/Library",
    "/tmp"
  ],
  "teammateMode": "tmux",
  "feedbackSurveyState": {
    "lastShownTime": 1754090074729
  },
  "effortLevel": "medium",
  "writePaths": [
    "/Users/natemccoy/.cargo",
    "/Users/natemccoy/Library/Caches/Mozilla.sccache",
    "/Users/natemccoy/rust",
    "/tmp"
  ]
}
