{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1",
    "TMPPREFIX": "/tmp/claude/zsh"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(gh *)",
      "Bash(git add *)",
      "Bash(git blame *)",
      "Bash(git branch *)",
      "Bash(git clean *)",
      "Bash(git commit *)",
      "Bash(git config *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git merge *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git remote *)",
      "Bash(git reset *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git stash list *)",
      "Bash(git status *)",
      "Bash(git tag *)",
      "Bash(git worktree *)",
      "Bash(mkdir *)",
      "Bash(rg *)",
      "Bash(rm *)",
      "Bash(run_test.sh *)",
      "Bash(sccache *)",
      "Bash(~/.claude/scripts/release/*)",
      "Bash(//Users/natemccoy/Library/Caches/Mozilla.sccache/**)",
      "Bash(//Users/natemccoy/rust/**/.git/**)",
      "Edit(//Users/natemccoy/.claude/**)",
      "Edit(//Users/natemccoy/Library/Application Support/**)",
      "Edit(//tmp/claude/**)",
      "Read(//Users/natemccoy/.cargo/registry/src**)",
      "Read(//Users/natemccoy/Library/Application Support/**)",
      "Read(//Users/natemccoy/rust/**)",
      "Read(//tmp/**)",
      "Read(//var/folders/rf/twhh0jfd243fpltn5k0w1t980000gn/T/**)",
      "Read(/private/tmp*)",
      "Write(//tmp/claude/**)"
    ],
    "deny": [
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git stash:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/natemccoy/Library",
      "/Users/natemccoy/rust",
      "/tmp",
      "/tmp/claude/"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /tmp/claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/hooks/post-tool-use-random-ack.sh --hook"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 /Users/natemccoy/.claude/scripts/hooks/post-tool-use-basedpyright.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd // empty'); [ -z \"$dir\" ] && dir=$(pwd); tok=$(echo \"$input\" | jq -r '.context_window.total_input_tokens // 0'); tok_fmt=$(LC_ALL=en_US.UTF-8 printf \"%'d\" \"$tok\"); model=$(echo \"$input\" | jq -r '.model.display_name // empty'); effort=$(echo \"$input\" | jq -r '.effort.level // empty'); model_fmt=\"$model\"; [ -n \"$effort\" ] && model_fmt=\"$model $effort\"; printf \"%s | %s | %s\" \"$(basename \"$dir\")\" \"$tok_fmt\" \"$model_fmt\""
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "index.crates.io",
        "raw.githubusercontent.com",
        "static.crates.io"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "/Users/natemccoy/.cargo",
        "/Users/natemccoy/Library/Application Support",
        "/Users/natemccoy/Library/Caches/Mozilla.sccache",
        "/Users/natemccoy/rust",
        "/private/tmp",
        "/tmp"
      ]
    },
    "excludedCommands": [
      "cargo",
      "gh",
      "git",
      "taplo",
      "~/.claude/scripts/validate_and_push/validate_ci.sh"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "teammateMode": "tmux",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754090074729
  }
}
